# Ignore everything by default. Opt in only the dotfiles and vendored runtime
# files that are needed to reproduce the CLI environment.
*

!/.gitignore
!/README.md

!/.config/
!/.config/.gitignore
!/.config/README.md
!/.config/nvim/
!/.config/nvim/**
!/.config/tmux/
!/.config/tmux/**
!/.config/starship.toml

!/.local/
!/.local/share/
!/.local/share/nvim/
!/.local/share/nvim/lazy/
!/.local/share/nvim/lazy/**
!/.local/share/nvim/site/
!/.local/share/nvim/site/**

# Plugin repositories are vendored as plain files for offline use.
.local/share/nvim/lazy/**/.git/

# Strip non-runtime plugin repository files from the offline vendor snapshot.
.local/share/nvim/lazy/**/.github/
.local/share/nvim/lazy/**/demo/
.local/share/nvim/lazy/**/docs/
.local/share/nvim/lazy/**/tests/
.local/share/nvim/lazy/**/test/
.local/share/nvim/lazy/**/spec/
.local/share/nvim/lazy/**/specs/
.local/share/nvim/lazy/**/.appveyor.yml
.local/share/nvim/lazy/**/.editorconfig
.local/share/nvim/lazy/**/.gitattributes
.local/share/nvim/lazy/**/.gitignore
.local/share/nvim/lazy/**/.luacheckrc
.local/share/nvim/lazy/**/.lua-format
.local/share/nvim/lazy/**/.luarc*
.local/share/nvim/lazy/**/.markdownlint*
.local/share/nvim/lazy/**/.neoconf.json
.local/share/nvim/lazy/**/.travis.yml
.local/share/nvim/lazy/**/.vintrc*
.local/share/nvim/lazy/**/.stylua*
.local/share/nvim/lazy/**/stylua.toml
.local/share/nvim/lazy/**/selene.toml
.local/share/nvim/lazy/**/AGENTS.md
.local/share/nvim/lazy/**/Dockerfile
.local/share/nvim/lazy/**/LICENSE*
.local/share/nvim/lazy/**/Makefile
.local/share/nvim/lazy/**/NOTICE
.local/share/nvim/lazy/**/README*
.local/share/nvim/lazy/**/CHANGELOG*
.local/share/nvim/lazy/**/Changelog*
.local/share/nvim/lazy/**/CONTRIBUTING*
.local/share/nvim/lazy/**/run-tests*
.local/share/nvim/lazy/**/run_tests*
.local/share/nvim/lazy/**/supported-tools.md
.local/share/nvim/lazy/**/tutorialrc
.local/share/nvim/lazy/**/TODO*
